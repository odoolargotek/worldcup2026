rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth.uid == 'j4nrnj5mFfYkwXSbXYs46MqFf2p2';
    }

    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid || isSuperAdmin();
    }

    match /groups/{gid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.owner_uid || isSuperAdmin();
    }

    match /group_members/{mid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.user_uid == request.auth.uid;
      allow update: if request.auth != null && (
                       request.resource.data.user_uid == request.auth.uid ||
                       resource.data.user_uid == request.auth.uid ||
                       get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.owner_uid == request.auth.uid ||
                       isSuperAdmin()
                    );
      allow delete: if request.auth != null && (
                       resource.data.user_uid == request.auth.uid ||
                       get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.owner_uid == request.auth.uid ||
                       isSuperAdmin()
                    );
    }

    match /matches/{mid} {
      allow read:             if request.auth != null;
      allow create, update:   if request.auth != null;
      allow delete:           if isSuperAdmin();
    }

    match /predictions/{pid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && (
                       request.resource.data.user_uid == request.auth.uid ||
                       isSuperAdmin()
                    );
      allow update: if request.auth != null && (
                       request.resource.data.user_uid == request.auth.uid ||
                       isSuperAdmin()
                    );
      allow delete: if request.auth != null && (
                       resource.data.user_uid == request.auth.uid ||
                       isSuperAdmin()
                    );
    }

    // Auditoría de cambios manuales en pronósticos — solo superAdmin escribe y lee
    match /prediction_audit/{auditId} {
      allow read:   if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /notifications/{uid}/items/{notifId} {
      allow create: if request.auth != null;
      allow read:   if request.auth.uid == uid;
    }

    match /app_config/{docId} {
      allow read:  if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /standings/{docId} {
      allow read:  if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /welcome_messages/{msgId} {
      allow read:   if request.auth != null;
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       (request.auth != null &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seen_by']));
    }

    match /chats/{gid}/messages/{msgId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.uid || isSuperAdmin();
    }

    match /dms/{channelId}/messages/{msgId} {
      allow read:   if request.auth != null &&
                       channelId.matches('.*' + request.auth.uid + '.*');
      allow create: if request.auth != null &&
                       channelId.matches('.*' + request.auth.uid + '.*') &&
                       request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.uid || isSuperAdmin();
    }

  }
}
