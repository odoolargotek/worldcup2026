rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Cualquier usuario autenticado puede leer su perfil; solo él puede escribirlo
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid;
    }

    // Grupos: cualquier auth puede leer; crear si autenticado
    match /groups/{gid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      // Solo el owner puede actualizar/borrar
      allow update, delete: if request.auth.uid == resource.data.owner_uid;
    }

    // Membresías
    match /group_members/{mid} {
      allow read: if request.auth != null;

      // Crear: solo el propio usuario puede crear su membresía
      allow create: if request.auth != null &&
                       request.resource.data.user_uid == request.auth.uid;

      // Actualizar: el propio miembro O el admin/owner del grupo
      allow update: if request.auth != null && (
                       request.resource.data.user_uid == request.auth.uid ||
                       resource.data.user_uid == request.auth.uid ||
                       get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.owner_uid == request.auth.uid
                    );

      // Borrar: el propio miembro O el owner del grupo puede eliminar
      allow delete: if request.auth != null && (
                       resource.data.user_uid == request.auth.uid ||
                       get(/databases/$(database)/documents/groups/$(resource.data.group_id)).data.owner_uid == request.auth.uid
                    );
    }

    // Partidos: solo lectura para usuarios auth; escritura solo desde admin
    match /matches/{mid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null; // TODO: restringir a admin con claims
    }

    // Pronósticos: el usuario solo escribe/lee los suyos
    match /predictions/{pid} {
      allow read:  if request.auth != null;
      allow create, update: if request.auth != null &&
                               request.resource.data.user_uid == request.auth.uid;
    }

    // Notificaciones de pago: el cliente (admin del grupo) crea el doc
    // que dispara la Cloud Function onPaymentNotification vía FCM.
    // Solo el usuario destinatario puede leer sus propias notificaciones.
    match /notifications/{uid}/items/{notifId} {
      allow create: if request.auth != null;
      allow read:   if request.auth.uid == uid;
    }

  }
}
