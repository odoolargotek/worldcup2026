{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/js/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "/css/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ]
}
